// =============================
// Models
// =============================

sealed trait EnergySource {
  def name: String
}

case object Solar extends EnergySource {
  val name: String = "Solar"
}

case object Wind extends EnergySource {
  val name: String = "Wind"
}

case object Hydro extends EnergySource {
  val name: String = "Hydro"
}

object EnergySource {
  def fromString(value: String): Either[String, EnergySource] =
    value.trim.toLowerCase match {
      case "solar" => Right(Solar)
      case "wind"  => Right(Wind)
      case "hydro" => Right(Hydro)
      case other    => Left(s"Invalid energy source: '$other'. Use Solar, Wind, or Hydro.")
    }

  val all: List[EnergySource] = List(Solar, Wind, Hydro)
}

case class EnergyRecord(
    id: Int,
    source: EnergySource,
    date: LocalDate,
    hour: Int,
    energyGeneratedKwh: Double,
    storageCapacityKwh: Double,
    equipmentStatus: String
)

case class PlantView(
    totalGeneratedKwh: Double,
    totalStorageCapacityKwh: Double,
    records: List[EnergyRecord]
)

sealed trait AlertLevel {
  def label: String
}

case object WarningLevel extends AlertLevel {
  val label: String = "WARNING"
}

case object CriticalLevel extends AlertLevel {
  val label: String = "CRITICAL"
}

case class Alert(
    recordId: Int,
    source: EnergySource,
    date: LocalDate,
    hour: Int,
    level: AlertLevel,
    message: String
)

case class StatisticsResult(
    mean: Double,
    median: Double,
    modes: List[Double],
    range: Double,
    midrange: Double
)

// =============================
// Date utilities and validation
// =============================

object DateUtil {
  val formatter: DateTimeFormatter = DateTimeFormatter.ofPattern("dd/MM/yyyy")

  def parseDate(input: String): Either[String, LocalDate] =
    Try(LocalDate.parse(input.trim, formatter)) match {
      case Success(date) => Right(date)
      case Failure(_: DateTimeParseException) =>
        Left(
          "Invalid date format. Please enter the date in the format 'DD/MM/YYYY'. " +
            "For example, enter '12/04/2024' for April 12, 2024."
        )
      case Failure(exception) => Left(s"Date error: ${exception.getMessage}")
    }

  def formatDate(date: LocalDate): String = date.format(formatter)
}

// =============================
// CSV Storage
// Imperative-style file I/O as requested
// =============================

object CsvStorage {
  private val header: String =
    "id,source,date,hour,energyGeneratedKwh,storageCapacityKwh,equipmentStatus"

  def ensureFileExists(filePath: String): Unit = {
    val file = new File(filePath)
    if (!file.exists()) {
      val writer = new PrintWriter(file)
      try writer.println(header)
      finally writer.close()
    }
  }

  def writeRecords(filePath: String, records: List[EnergyRecord]): Unit = {
    val writer = new PrintWriter(new File(filePath))
    try {
      writer.println(header)
      records.foreach(record => writer.println(toCsv(record)))
    } finally writer.close()
  }

  def appendRecord(filePath: String, record: EnergyRecord): Unit = {
    ensureFileExists(filePath)
    val writer = new java.io.FileWriter(filePath, true)
    try writer.write(toCsv(record) + System.lineSeparator())
    finally writer.close()
  }

  def readRecords(filePath: String): Either[String, List[EnergyRecord]] = {
    ensureFileExists(filePath)

    Try {
      val source = Source.fromFile(filePath)
      try {
        source.getLines().drop(1).toList
      } finally source.close()
    } match {
      case Failure(exception) => Left(s"Could not read CSV file: ${exception.getMessage}")
      case Success(lines) =>
        val parsed = lines.filter(_.trim.nonEmpty).map(parseCsvLine)
        collectEither(parsed)
    }
  }

  private def toCsv(record: EnergyRecord): String =
    List(
      record.id.toString,
      record.source.name,
      DateUtil.formatDate(record.date),
      record.hour.toString,
      record.energyGeneratedKwh.toString,
      record.storageCapacityKwh.toString,
      record.equipmentStatus
    ).mkString(",")

  private def parseCsvLine(line: String): Either[String, EnergyRecord] = {
    val parts = line.split(",", -1).map(_.trim).toList

    parts match {
      case idText :: sourceText :: dateText :: hourText :: energyText :: storageText :: status :: Nil =>
        for {
          id      <- parseInt(idText, "id")
          source  <- EnergySource.fromString(sourceText)
          date    <- DateUtil.parseDate(dateText)
          hour    <- parseHour(hourText)
          energy  <- parseDouble(energyText, "energyGeneratedKwh")
          storage <- parseDouble(storageText, "storageCapacityKwh")
        } yield EnergyRecord(id, source, date, hour, energy, storage, status)

      case _ => Left(s"Invalid CSV line: $line")
    }
  }

  private def parseInt(value: String, fieldName: String): Either[String, Int] =
    Try(value.toInt).toEither.left.map(_ => s"Invalid integer in field '$fieldName': $value")

  private def parseDouble(value: String, fieldName: String): Either[String, Double] =
    Try(value.toDouble).toEither.left.map(_ => s"Invalid number in field '$fieldName': $value")

  private def parseHour(value: String): Either[String, Int] =
    parseInt(value, "hour").flatMap { hour =>
      if (hour >= 0 && hour <= 23) Right(hour)
      else Left("Invalid hour. Hour must be between 0 and 23.")
    }

  private def collectEither[A](values: List[Either[String, A]]): Either[String, List[A]] =
    values.foldRight(Right(Nil): Either[String, List[A]]) { (item, accumulator) =>
      for {
        value <- item
        list  <- accumulator
      } yield value :: list
    }
}

